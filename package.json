{
  "name": "algorithms-study",
  "private": true,
  "description": "TypeScript-first interview problem study workspace.",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "test": "vitest run studies/problems/making-anagrams --passWithNoTests",
    "test:watch": "vitest studies/problems/making-anagrams --passWithNoTests",
    "run": "tsx",
    "verify": "pnpm check-types && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
