{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "esModuleInterop": false,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["studies/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
